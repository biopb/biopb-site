# Large demo videos are managed directly on the server (excluded from rsync deploy)
*.mp4

# MkDocs build output (built in CI, deployed to /docs) and local docs virtualenv
site/
.venv-docs/
# Social-card plugin font/render cache (created by `mkdocs build`)
.cache/

# Skill catalog is generated by scripts/build_skills_catalog.py in CI before rsync
# (source of truth is skills/*.md). See docs/skill-interface.md in the biopb repo.
skills/catalog.json

# Python bytecode
__pycache__/
*.pyc
